# ─────────────────────────────────────────────────────────────────────────────
# ebay-terapeak-mcp — Environment Variables (all optional)
#
# This server drives a persistent CloakBrowser session logged into eBay Seller
# Hub. Log in once with `npm run login`; the session is saved to the profile dir
# below and reused. Set these in your MCP client's `env` block, or copy this file
# to `.env` when developing from a checkout.
# ─────────────────────────────────────────────────────────────────────────────

# Browser profile dir (holds your eBay session — never commit it).
# Default: ~/.ebay-research-mcp/profile
# EBAY_MCP_PROFILE=/home/you/.ebay-research-mcp/profile

# Set 0 to run headed if bot detection blocks headless.
EBAY_MCP_HEADLESS=1

# Timezone string sent to eBay (e.g. Asia/Jakarta).
EBAY_MCP_TZ=UTC
